# define compiler options

# GNU compiler family:
# Compiler
#CPP=g++
## Optimization flags
CPPFLAGS= -Ofast -ffast-math -freorder-blocks-and-partition -floop-interchange -floop-strip-mine -floop-block  -ftree-loop-if-convert -ftree-loop-if-convert-stores -ftree-loop-distribution -ftree-vectorize -fno-exceptions -fno-rtti # -floop-parallelize-all
# Debugging flags
#CPPFLAGS= -g -Wall
# multithread option:
CPPFLAGS+= -fopenmp

# Intel compilers
#CPP=icc
# Optimization flags
#CPPFLAGS= -O3
# Debugging flags
#CPPFLAGS= -g
# multithread option:
#CPPFLAGS+= -openmp

# MPI options, 
CPP=mpic++
CPPFLAGS+= -D USE_MPI


# macros
RM = rm -f

#DIR1D=/media/mat06/ef4528ca-8f88-4570-96e4-ec46e3c9cf04/ADAVN/TRANSPORT/fvm-control
DIR1D=../fvm
# libraries
LIBDEPS = $(DIR1D)/lib1dsolvermpi.a
LDFLAGS = $(DIR1D)/lib1dsolvermpi.a -lm -lblas -llapack -lmetis
#LDFLAGS = $(DIR1D)/lib1dsolver.a -L/usr/lib64/atlas -lcblas -lblas -llapack  -lm 
# paths to include files (out of current directory)
INCLUDES = -I$(DIR1D)

# output
EXEC=1d_fvm-control.x

# input

INPUT=main.cc


DIRS := ./
FILES:= $(INPUT) $(foreach DIR,$(DIRS),$(wildcard $(DIR)/*.h))
SRCS := $(notdir $(INPUT))
# rule to create object files
OBJS := $(SRCS:.cc=.o)

 
.PHONY: all clean

all: $(EXEC) $(TARGET) 

$(EXEC): $(OBJS) $(LIBDEPS)
	$(CPP) $(CPPFLAGS) $(INCLUDES) $(OBJS) $(LDFLAGS) -o $@

%.o : %.cc
	$(CPP) $(CPPFLAGS)  $(INCLUDES) -c $< -o $@

clean: 	
	rm -f *.o 1d_fvm-control.x
